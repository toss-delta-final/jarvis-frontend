# 이 파일을 .env.local 로 복사해 값 채우기 (.env.local 은 커밋 안 됨)

# axios baseURL — 앱이 실제로 API 요청을 쏘는 주소.
#   로컬: 비워둔다 → 요청이 /api/... 상대경로로 나가 아래 proxy가 백엔드로 전달(CORS·쿠키 문제 없음).
#   배포: 실 백엔드 주소를 넣는다 → proxy가 없으므로 그 주소로 직결(백엔드 CORS 허용 필요).
VITE_API_BASE_URL=

# proxy 대상 — vite dev 서버 전용(배포에선 무시됨). 로컬에서 /api 요청을 넘길 Spring 백엔드 주소.
#   로컬 백엔드: http://localhost:8080 / 배포 백엔드에 붙으려면 그 주소를 넣는다.
VITE_SPRING_BASE_URL=http://localhost:8080

# MSW 목 활성화 스위치 (dev/배포 무관). 기본은 실제 백엔드 연동.
# 백엔드 없이 화면 확인·데모할 때만 true로 켠다. 켜면 모든 API가 목 응답으로 대체됨.
VITE_ENABLE_MOCKS=false
