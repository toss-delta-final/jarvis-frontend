# 이 파일을 .env.local 로 복사해 값 채우기 (.env.local 은 커밋 안 됨)

# 백엔드 API 주소. 비우면 요청이 상대경로(/api/...)로 나감
VITE_API_BASE_URL=http://localhost:8080

# (참고) 셀러 챗 AI 서버 주소는 프론트가 지정하지 않는다 —
# 세션 발급(POST /api/chat/seller/sessions) 응답의 llmSseUrl 을 그대로 SSE 엔드포인트로 쓴다.

# MSW 목 활성화 스위치 (dev/배포 무관). 기본은 실제 백엔드 연동.
# 백엔드 없이 화면 확인·데모할 때만 true로 켠다. 켜면 모든 API가 목 응답으로 대체됨.
VITE_ENABLE_MOCKS=false
